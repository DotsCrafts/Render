{
  "name": "render-browser",
  "version": "0.1.0",
  "private": true,
  "description": "Render — a Chromium browser whose brain is an agent. agent(brain) + opencli(app hand) + sandbox(sandbox hand) + chromium CDP(human hand).",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"]
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "dev": "pnpm --filter @render/desktop dev",
    "start": "pnpm --filter @render/desktop start",
    "package:mac": "pnpm --filter @render/desktop package:mac",
    "package:linux": "pnpm --filter @render/desktop package:linux"
  }
}
